rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - familyId: string (optional)
    //   - role: string (optional, enum: ["student", "guardian"])
    //
    // Collection: families
    // Fields:
    //   - name: string (required)
    //   - createdBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: scholarships
    // Fields:
    //   - title: string (required)
    //   - amount: number (optional)
    //   - deadline: timestamp (optional)
    //   - status: string (required, enum: ["intake", "not_applicable", "need_to_apply", "in_progress", "applied"])
    //   - url: string (optional)
    //   - notes: string (optional)
    //   - applicableStudents: list (optional)
    //   - familyId: string (required)
    //   - addedBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isInFamily(familyId) {
      return isAuthenticated() && getUserData().familyId == familyId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             (!('familyId' in data) || data.familyId is string) &&
             (!('role' in data) || data.role in ['student', 'guardian']);
    }

    function isValidFamily(data) {
      return data.keys().hasAll(['name', 'createdBy', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdBy == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidScholarship(data) {
      return data.keys().hasAll(['title', 'familyId', 'addedBy', 'createdAt', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.familyId is string &&
             data.addedBy is string &&
             data.createdAt is timestamp &&
             data.status in ['intake', 'not_applicable', 'need_to_apply', 'in_progress', 'applied'] &&
             (!('amount' in data) || data.amount == null || data.amount is number) &&
             (!('url' in data) || data.url == null || data.url is string) &&
             (!('notes' in data) || data.notes == null || data.notes is string) &&
             (!('deadline' in data) || data.deadline == null || data.deadline is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('academicYear' in data) || data.academicYear == null || data.academicYear is string) &&
             (!('applicableStudents' in data) || data.applicableStudents is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || getUserData().familyId == resource.data.familyId);
      allow create: if (isOwner(userId) || (isAuthenticated() && userId.matches("^demo_.*") && request.resource.data.familyId == getUserData().familyId)) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId) || (isAuthenticated() && userId.matches("^demo_.*") && resource.data.familyId == getUserData().familyId);
    }

    match /families/{familyId} {
      allow read: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isInFamily(familyId));
      allow create: if isAuthenticated() && isValidFamily(request.resource.data);
      allow update: if isInFamily(familyId) && isValidFamily(request.resource.data);
    }

    match /scholarships/{scholarshipId} {
      allow read: if isAuthenticated() && isInFamily(resource.data.familyId);
      allow create: if isAuthenticated() && isInFamily(request.resource.data.familyId) && 
                      request.resource.data.addedBy == request.auth.uid &&
                      isValidScholarship(request.resource.data);
      allow update: if isAuthenticated() && isInFamily(resource.data.familyId) && 
                      isValidScholarship(request.resource.data) &&
                      request.resource.data.addedBy == resource.data.addedBy &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isInFamily(resource.data.familyId);
    }
  }
}
